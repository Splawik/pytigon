                {
                    "model": "SChView",
                    "attributes": {
                        "name": "excel_report",
                        "view_type": "u",
                        "param": "**argv",
                        "url": "excel/",
                        "view_code": "object_list = []\n\nfor i in range(1,10000):\n    object_list.append( ( 'title '+ str(i), i) )\n\nreturn { 'doc_type': 'xlsx', 'object_list': object_list, \"sheet_names\": [\"abc\", \"def\"], \"sheet_name\": \"abc\" }\n",
                        "url_params": "{}",
