                {
                    "model": "SChFile",
                    "attributes": {
                        "type": "j",
                        "name": "sample",
                        "content": "PROMISE = None\nDB = None\n\nasync def get_demo_database(module):\n    if not PROMISE:\n        todoSchema = {\n            \"version\": 0,\n            \"primaryKey\": 'id',\n            \"type\": 'object',\n            \"properties\": {\n                \"id\": { \"type\": 'string', \"maxLength\": 36 },\n                \"title\": { \"type\": 'string' },\n                \"done\": { \"type\": 'boolean' },\n                \"createdAt\": { \"type\": 'string', \"format\": 'date-time' }\n            },\n            \"required\": ['title', 'done']\n        }\n        async def initDatabase():\n            nonlocal DB\n            if not DB:\n                DB = await module.createRxDatabase({\n                    \"name\": 'pytigon_demo',\n                    \"storage\": module.getRxStorageDexie() \n                })\n                await DB.addCollections({\n                    \"todos\": {\n                        \"schema\": todoSchema\n                    }\n                })\n                \n                def _pre_insert(docData):\n                    if not docData.id:\n                        docData.id = window.v7() \n                    if not docData.createdAt: \n                        docData.createdAt = Date().toISOString()\n                        \n                DB.todos.preInsert(_pre_insert)\n                \n            return DB\n        PROMISE = initDatabase()\n    return PROMISE\n\n\ndef request(param, complete):\n    def on_load(module):\n        def on_error(err):\n            console.error(err)\n                 \n        def test2(db):\n            uncompletedTodos = None\n\n            async def test():                \n                newTodos = [\n                    {\n                        \"title\": 'Buy groceries',\n                        \"isCompleted\": False,\n                    },\n                    {\n                        \"title\": 'Read RxDB documentation',\n                        \"isCompleted\": True,\n                    }\n                ]\n\n                insertResult = await db.todos.bulkInsert(newTodos)\n                uncompletedTodos = await db.todos.find({\"selector\": {\"isCompleted\": False}}).exec()\n                                \n                table = Array.prototype.slice.call(uncompletedTodos)\n                table2 = []\n                for row in table:\n                    console.log(\"- \", row.id, row.title, row.createdAt)\n                    table2.append({'id': row.id, 'title': row.title, 'createdAt': row.createdAt, 'isCompleted': row.isCompleted })\n                \n                return table2\n            \n            def go(table):\n                console.log(table)\n                context = {\n                    \"template\": '.',\n                    \"table\": table\n                }\n                complete(context)\n\n            test().then(go)\n\n        get_demo_database(module).then(test2)\n\n    window.jsimp(\"http://127.0.0.1:8000/static/_schcomponents/rxdb/rxdb.js\", on_load)\n    ",
                        "doc": null
                    }
                },
                {
                    "model": "SChFile",
                    "attributes": {
                        "type": "T",
                        "name": "sample",
                        "content": "body:\n    h1...Hello world!\n    <pre>{{ global | json }}</pre>\n    <!-- lub je\u015bli u\u017cywasz nowszej wersji Liquidjs -->\n    <pre>{{ _context | json }}</pre> \n\n    {{ table.size }}\n    % for row in table:\n        {{ row }}, {{ row.id }}: {{ row.title }} {{ row.createdAt }} {{ row.done }} <br />\n",
                        "doc": null
                    }
                },
                {
                    "model": "SChFile",
                    "attributes": {
                        "type": "j",
                        "name": "login_form",
                        "content": "def request(param, complete):\n    token = localStorage.getItem('api_token')\n    \n    if token:\n        auth = True\n    else:\n        auth = False\n    \n    context = {\n        \"template\": '.',\n        \"auth\": auth\n    }\n    \n    complete(context)\n",
                        "doc": null
                    }
                },
                {
                    "model": "SChFile",
                    "attributes": {
                        "type": "T",
                        "name": "login_form",
                        "content": "% if auth:\n    h1...You are already authorized\n    \ndiv class=container login-container\n    div class=row align-items-center\n        div class=col\n        div class=col-lg-6 col-xl-5\n            div class=card card-inverse login-card\n                %% login_card\n                    div class=card-header\n                        {{prj_title|upper}}\n                    div class=card-block\n                        br\n                        p id=login_txt1..._(Sign in):\n                        p id=login_txt2,,,class=d-none..._(Wrong login or password, try again):\n                        br\n                        form class=login-form,,,action=/static/schcomponents_demo/views/login.fview,,,method=post,,,name=signin,,,target=refresh_page\n                            div class=form-group\n                                label class=control-label,,,for=username_ ..._(User name)\n                                div class=input-group\n                                    div class=input-group-addon fa fa-user\n                                    input class=form-control,,,type=text,,,size=25,,,maxlength=30,,,id=username_,,,name=username,,,value=,,,autocomplete=username\n                            div class=form-group mb-3\n                                label class=control-label,,,for=password_..._(Password)\n                                div class=input-group\n                                    div class=input-group-addon fa fa-key\n                                    input class=form-control,,,type=password,,,size=25,,,maxlength=30,,,id=password_,,,name=password,,,value=,,,autocomplete=current-password\n                            div class=row\n                                div class=col\n                                div class=col div_content_center\n                                    button type=submit,,,class=btn btn-primary btn-lg ...OK\n                                div class=col\n        div class=col\n",
                        "doc": null
                    }
                },
                {
                    "model": "SChFile",
                    "attributes": {
                        "type": "j",
                        "name": "login",
                        "content": "def request(param, complete):\n        \n    def _callback(result):\n        localStorage.setItem('api_token', result.data.tokenAuth.token)\n        context = {\n            \"template\": '.',\n            \"param\": result\n        }\n        complete(context)\n\n    data = {\n        \"query\": \"mutation ($username: String!, $password: String!) { tokenAuth(username: $username, password: $password) { token } }\",\n        \"variables\": { 'username': param.username, 'password': param.password }\n    }\n    \n    window.graphql_public_client(data, _callback)\n    ",
                        "doc": null
                    }
                },
                {
                    "model": "SChFile",
                    "attributes": {
                        "type": "T",
                        "name": "login",
                        "content": "h1...Login\n{{param.username}}\n",
                        "doc": null
                    }
                },
                {
                    "model": "SChFile",
                    "attributes": {
                        "type": "j",
                        "name": "users",
                        "content": "def request(param, complete):\n        \n    def _callback(result):\n        context = {\n            \"template\": '.',\n            \"users\": result.data[\"users\"]\n        }\n        complete(context)\n\n    data = {\n        \"query\": \"query { users { id, username, email } }\",\n    }\n    \n    window.graphql_client(data, _callback)\n    ",
                        "doc": null
                    }
                },
                {
                    "model": "SChFile",
                    "attributes": {
                        "type": "T",
                        "name": "users",
                        "content": "h1...Results:\n\n.A1\n{{users}}\n.A2\n\n% for user in users:    \n    .x<br/>\n    {{ user.id }}, {{ user.username }}, {{ user.email }} <br/>\n",
                        "doc": null
                    }
                }
            ]
        },
