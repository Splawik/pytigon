        {
            "model": "SChStatic",
            "attributes": {
                "type": "R",
                "name": "clock-channel",
                "content": "TAG = 'ptig-clock-channel'\n\nTEMPLATE = \"\"\"<div name='clock'>See console messages!<slot></slot></div>\"\"\"\n    \nwith DefineWebComponent(TAG, False) as comp:\n    \n    #comp.options['template'] = TEMPLATE\n\n    def init(component):\n        component.timer = None\n        component.websocket = None\n\n        address = location.hostname \n        \n        if location.port:\n            address += \":\"+ location.port\n        \n        if component.hasAttribute('websocket_href'):\n            address += component.getAttribute('websocket_href')\n                            \n        if location.protocol != 'https:':\n            address = 'ws://' + address\n        else:\n            address = 'wss://' + address\n        \n        component.websocket = WebSocket(address)\n          \n        def on_timer():\n            nonlocal component\n            if component.websocket:\n                component.websocket.send(JSON.stringify ({'status': 'ping', 'data': 1}))\n                console.log(\"SEND: \", 'ping')\n\n        component.timer = setInterval(on_timer, 10000)\n                        \n        def _on_websocket_open():\n            nonlocal component\n            div = component #.shadowRoot.querySelector('div')                \n            def _on_message(evt):\n                nonlocal div\n                jdata = JSON.parse(evt.data)\n                status = jdata['status']\n                if status == \"pong\":\n                    console.log(\"RECEIVED: pong\")\n                    console.log(jdata.data)\n                elif status == \"clock\":\n                    console.log(\"RECEIVED: clock\")\n                    console.log(jdata.data)\n                else:\n                    console.log(\"RECEIVED: unknown message\")\n                    console.log(evt.data)\n                    console.log(\"-----------------------------------\")\n                \n            component.websocket.onmessage = _on_message\n            \n\n        component.websocket.onopen  = _on_websocket_open\n    comp.options[\"init\"] = init\n\n    def disconnectedCallback(component):        \n        window.clearInterval (component.timer)\n        component.timer = None\n        \n        def _on_close():\n            nonlocal  component\n            component.websocket = None\n                \n        component.websocket.onclose = _on_close\n        \n        if component.websocket:\n            component.websocket.close()\n            component.websocket = None\n\n        print(\"disconnectedCallbaack()\")\n    comp.options[\"disconnectedCallback\"] = disconnectedCallback\n",
                "doc": null
            }
        },
        {
