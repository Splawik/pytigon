                "content": "TAG = 'test-options'\n\nTEMPLATE = \"\"\" \n    ul data-bind=data\n\"\"\"\n\nwith DefineWebComponent(TAG, True) as comp:\n    comp.options[\"attributes\"] = {\"width\": None, \"height\": None,}\n        \n    comp.options['template'] = TEMPLATE\n    \n    def init(component):        \n        data = \"\"\n        for child in Array.prototype.slice.call(component.children):\n            data += \"<li>\" + child.innerHTML + \"</li>\"\n        component.set_state({\"data\": data})\n    comp.options['init'] = init\n",
                "doc": null
