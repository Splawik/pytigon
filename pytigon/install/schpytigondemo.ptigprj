                        "url_parm": null,
                        "template_code": "% extends \"forms/form.html\"\n\n% load exfiltry\n% load exsyntax\n\n\n%% content\n    ptig-wysiwygedit width=100%,,,height=600px,,,namespace={{uuid}}_c1        \n        div class=toolbar,,,slot=toolbar,,,style=display: flex; flex-wrap: wrap; gap: 6px; align-items: center;\n            \n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=undo...<i class=\"fa fa-undo\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=redo...<i class=\"fa fa-repeat\"></i>\n\n            div class=divider\n\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleBold,,,style=font-weight: bold;...<i class=\"fa fa-bold\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleItalic,,,style=font-style: italic;...<i class=\"fa fa-italic\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleStrike,,,style=text-decoration: line-through;...<i class=\"fa fa-strikethrough\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleLink...<i class=\"fa fa-link\"></i>\n\n            div class=divider\n        \n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleHeading,,,data-level=1...<i class=\"fa fa-header\"></i>1\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleHeading,,,data-level=2...<i class=\"fa fa-header\"></i>2\n            \n            div class=divider\n\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleBulletList...<i class=\"fa fa-list-ul\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleOrderedList...<i class=\"fa fa-list-ol\"></i>\n\n            div class=divider\n\n            label class=color-picker\n                .<i class=\"fa fa-paint-brush\"></i>: <input type=\"color\" data-command-input=\"setColor\" value=\"#000000\">\n            label class=color-picker\n                .<i class=\"fa fa-tint\"></i>: <input type=\"color\" data-command-input=\"setHighlight\" value=\"#ffff00\">\n            \n            div class=divider\n\n\n            label class=my-btn file-upload\n                .<i class=\"fa fa-folder-open-o\"></i>\n                input type=file,,,accept=image/*,,,data-command-file=insertImageFile\n\n            div class=divider\n\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=insertTable...<i class=\"fa fa-table\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=addColumnAfter...<i class=\"fa fa-columns\"></i>+\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=deleteColumn...<i class=\"fa fa-columns\"></i>-\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=addRowAfter...<i class=\"fa fa-bars\"></i>+\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=deleteRow...<i class=\"fa fa-bars\"></i>-\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=deleteTable,,,style=color: red;...<i class=\"fa fa-trash\"></i>        \n\n        \n        <textarea name=\"text\">Abracadabra abracadabra</textarea>\n\n    br\n    \n    ptig-wysiwygedit width=100%,,,height=600px,,,namespace={{uuid}}_c2\n        div class=toolbar,,,slot=toolbar,,,style=display: flex; flex-wrap: wrap; gap: 6px; align-items: center;\n            ptig-action-btn event-name=save_click,,,label=Save,,,namespace={{uuid}}_c2\n            ptig-log-handler event-name=save,,,namespace={{uuid}}_c2\n            \n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=undo...<i class=\"fa fa-undo\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=redo...<i class=\"fa fa-repeat\"></i>\n\n            div class=divider\n\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleBold,,,style=font-weight: bold;...<i class=\"fa fa-bold\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleItalic,,,style=font-style: italic;...<i class=\"fa fa-italic\"></i>\n            button type=button,,,class=my-btn btn btn-outline-secondary,,,data-command=toggleStrike,,,style=text-decoration: line-through;...<i class=\"fa fa-strikethrough\"></i>\n",
                        "tags_mount": null,
