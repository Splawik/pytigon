                    "attributes": {
                        "name": "Formform_test",
                        "direct_to_template": null,
                        "url": null,
                        "url_parm": null,
                        "template_code": "% extends \"forms/user_tab.html\"\n\n% load exfiltry\n% load exsyntax\n\n%% all\n    %with form_width=800 form_height=600 show_title_bar=1 title='Form'\n        {{ block.super }}\n\n%% list_page_header\n    % if standard_web_browser != 6 or form.errors or errors:\n        h3...TEST FORM\n\n\n%% list_row_header\n    th...Col 1\n    th...Col 2\n    th...Col 3\n    th...Col 4\n    th...Col 5\n    th...Col 6\n    th...Col 7\n    th...Col 8\n\n%% list_full_row\n    tr\n        td... {{object.0}}\n        td... {{object.1}}\n        td... {{object.2}}\n        td... {{object.3}}\n        td... {{object.4}}\n        td align=right... {{object.5|floatnullformat}}\n        td... {{object.6}}\n        td align=right... {{object.7|floatnullformat}}\n        td... {{object.8}}\n",
                        "tags_mount": null,
                        "asynchronous": false
                    }
                },
