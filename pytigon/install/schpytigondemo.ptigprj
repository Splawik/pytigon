                {
                    "model": "SChTemplate",
                    "attributes": {
                        "name": "example_template",
                        "direct_to_template": true,
                        "url": "example_template/",
                        "url_parm": null,
                        "template_code": "@@@ markdown_example\n% load i18n\n \nhr\n<!-- html code -->\n<h1>Hello world!</h1>\nhr \n<!-- ihtml equivalent -->\nh1...Hello world!\nhr \n\n\nhr\n<!-- html code --> \n<table><tr><th>Title 1</th><th>Title2</th></tr><tr><td>Data 1</td><td>Data 2</td></tr></table>\nhr\n<!-- ihtml equivalent -->\ntable\n    tr\n        th...Title 1\n        th...Title 2\n    tr\n        td...Data 1\n        td...Data 2\nhr\n\n\nhr\n<!-- html code --> \n<div class=\"alert alert-primary\" role=\"alert\">\n  <button type=\"button\" class=\"btn btn-danger\">Danger</button>\n  <strong>Heads up!</strong> This <a href=\"#\" class=\"alert-link\">alert needs your attention</a>, but it's not super important.\n</div>\n<div class=\"test\" width=\"100%\"><span class=\"test2\">Test</span></div>\nhr\n<!-- ihtml equivalent -->\ndiv class=alert alert-primary,,,role=alert\n  button type=button,,,class=btn btn-danger...Danger\n  <strong>Heads up!</strong>This \n  a href=#,,,class=alert-link...alert needs your attention\n  .,but it's not super important.\ndiv class=test,,,width=100%:::span=test2...Test\nhr\n\n\nhr\n<!-- html code --> \n{% block title1 %}Title{% endblock %}\nhr\n<!-- ihtml equivalent -->\n%% title2\n    .Title\nhr\n\n\nhr\n<!-- html code --> \n{% for letter in \"abc\" %}letter: {{letter}}<br/>{% endfor %}\n{% if True %}Hello!{% endif %}\nhr\n<!-- ihtml equivalent -->\n% for letter in \"abc\":\n    .letter: {{letter}}\n    br\n% if True:\n    .Hello!\nhr\n\n\nhr\n<!-- html code --> \n<h3>do not process indented text</h3>def test(): <br>x = 10 <br>y = 20 <br>\n<br>\n<h4>finish!</h3>\nhr\n<!-- ihtml equivalent -->\nh3...do not process indented text\n===>\n    def test(): <br>\n        x = 10 <br>\n        y = 20 <br>\nbr\nh4...finish!\nhr\n\n\nhr\n<!-- html code --> \n<h3>do not process text block</h3>def test2(): <br>x = 10 <br>y = 20 <br>\n<br>\n<h4>finish!</h3>\n<!-- ihtml equivalent -->\nhr\nh3...do not process text block \n>>>\n    def test2(): <br>\n        x = 10 <br>\n        y = 20 <br>\n<<<\nbr\nh4...finish!\nhr\n\n\nhr\n<!-- html code --> \n<h3>Markdown block</h3>\n<h1>H1</h1>Test <strong>test</strong> <em>test</em>\nhr\n<!-- ihtml equivalent -->\nh3...Markdown block \n###>\n    #H1\n    \n    Test **test** *test*\n\nhr\n\nhr\n<!-- html code --> \n<h4>{% translate \"This is the title.\" %}</h4>\nhr\n<!-- ihtml equivalent -->\nh4..._(This is the title.) \nhr\n\n\nhr\n<!-- html code --> \n{% translate \"This is full line translated text\" %}\nhr\n<!-- ihtml equivalent -->\n_This is full line translated text\nhr\n\n\nhr\n<!-- html code --> \n.See page source\n<script language=\"python\">\n.def init_form(self):\n.    pass\n</script>\nhr\n<!-- ihtml equivalent -->\n.See page source\nscript language=python\n    def init_form(self):\n        pass\nhr\n\nhr\n<!-- html code --> \n.See page source\n<script>\n.function javascript_function() {\n.    console.log(\"Hello world!\");\n.}\n</script>\nhr\n<!-- ihtml equivalent -->\n.See page source\nscript\n    def javascript_function():\n        print(\"Hello world!\")\nhr\n\nhr\n<!-- html code --> \n.See page source\n<script>\n.function javascript_function() {\n.    console.log(\"Hello world!\");\n.}\n</script>\nhr\n<!-- ihtml equivalent -->\n.See page source\nscript language=javascript\n    .function javascript_function() {\n    .   console.log(\"Hello world!\");\n    .}\nhr\n\n\nhr\n<!-- html code --> \n.function test_js(a,b){ var a=10; a=a+1; if(a>1){ a=1 } return 0 }\nhr\n<!-- ihtml equivalent -->\n{:}\n    function test_js(a,b):\n        var a=10\n        a=a+1\n        if (a>1):\n            a=1\n        return 0\nhr\n\n###>\n    # H1\n    \n    ## H2\n    \n    ### H3\n\n    1. test\n    2. test2\n    \n    \n    - a1\n    - a2\n    \n    \n    Test *test* **test2**\n",
                        "tags_mount": null,
                        "asynchronous": false
                    }
                },
                {
                    "model": "SChTemplate",
                    "attributes": {
                        "name": "markdown_example",
                        "direct_to_template": null,
                        "url": null,
                        "url_parm": null,
                        "template_code": ".\n@@@\n<div class=\"wiki_container\">\n###>\n    Heading\n    =======\n\n    Sub-heading\n    -----------\n\n    # Alternative heading #\n\n    Paragraphs are separated \n    by a blank line.\n\n    Two spaces at the end of a line  \n    produce a line break.\n\n    Text attributes _italic_, **bold**, `monospace`.\n\n    Horizontal rule:\n\n    ---\n\n    Bullet lists nested within numbered list:\n\n      1. fruits\n         * apple\n         * banana\n      2. vegetables\n         - carrot\n         - broccoli\n         \n    A [link](http://example.com).\n\n    ![Image](Icon-pictures.png \"icon\")\n\n    > Markdown uses email-style characters for blockquoting.\n    >\n    > Multiple paragraphs need to be prepended individually.\n\n    Most inline <abbr title=\"Hypertext Markup Language\">HTML</abbr> is supported.\n\n\n    ## Markdown extensions\n\n    ### Abbreviations\n\n    The HTML specification\n    is maintained by the W3C.\n\n    *[HTML]: Hyper Text Markup Language\n    *[W3C]:  World Wide Web Consortium\n\n\n    ### Attribute Lists\n\n    This is a paragraph.\n    {: #an_id .a_class }\n\n\n    ### Definition Lists\n\n    Apple\n    :   Pomaceous fruit of plants of the genus Malus in\n        the family Rosaceae.\n\n    Orange\n    :   The fruit of an evergreen tree of the genus Citrus.\n\n\n    ### Fenced Code Blocks\n\n    ``` html\n    <p>HTML Document</p>\n    ```\n\n    ``` python\n    def test(x):\n        return x\n    ```\n\n    ### Tables\n\n    First Header  | Second Header\n    ------------- | -------------\n    Content Cell  | Content Cell\n    Content Cell  | Content Cell\n\n</div>",
                        "tags_mount": null,
                        "asynchronous": false
                    }
                },
