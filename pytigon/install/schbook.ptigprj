                {
                    "model": "SChView",
                    "attributes": {
                        "name": "borrow_book",
                        "view_type": "r",
                        "param": "pk",
                        "url": "Book",
                        "view_code": "from .models import Book\nfrom django.utils import timezone\n\nbook = Book.objects.get(pk=pk)\nif book.status != 'available':\n    return { 'OK': False, 'msg': 'Book is not available' }\n\nbook.status = 'borrowed'\nbook.save()\n\nborrow = models.Borrow(\n    book=book,\n    reader_name=request.user.get_full_name() or request.user.username,\n    reader_email=request.user.email,\n    borrow_date=timezone.now().date(),\n    planned_return_date=timezone.now().date() + timezone.timedelta(days=30)\n)\nborrow.save()\n\nreturn { 'OK': True, 'msg': 'Book borrowed successfully' }\n",
                        "url_params": null,
                        "ret_type": "T",
                        "asynchronous": false,
                        "extra_code": null,
                        "doc": null
                    }
                },
                {
                    "model": "SChView",
                    "attributes": {
                        "name": "return_book",
                        "view_type": "r",
                        "param": "pk",
                        "url": "Borrow",
                        "view_code": "from django.utils import timezone\n\nborrow = models.Borrow.objects.get(pk=pk)\nif borrow.return_date:\n    return { 'OK': False, 'msg': 'Book already returned' }\n\nborrow.return_date = timezone.now().date()\nborrow.save()\n\nreturn { 'OK': True, 'msg': 'Book returned successfully' }\n",
                        "url_params": null,
                        "ret_type": "T",
                        "asynchronous": false,
                        "extra_code": null,
                        "doc": null
                    }
                },
                {
                    "model": "SChView",
                    "attributes": {
                        "name": "withdraw_book",
                        "view_type": "r",
                        "param": "pk",
                        "url": "Book",
                        "view_code": "from .models import Book\n\nbook = Book.objects.get(pk=pk)\nif book.status == 'borrowed':\n    return { 'OK': False, 'msg': 'Cannot withdraw a borrowed book. Wait for return first.' }\n\nbook.status = 'withdrawn'\nbook.save()\n\nreturn { 'OK': True, 'msg': 'Book withdrawn from library' }\n",
                        "url_params": null,
                        "ret_type": "T",
                        "asynchronous": false,
                        "extra_code": null,
                        "doc": null
                    }
                },
                {
                    "model": "SChTemplate",
                    "attributes": {
                        "name": "Book",
                        "direct_to_template": null,
                        "url": null,
                        "url_parm": null,
                        "template_code": "{# -*- coding: utf-8 -*- #}\n% extends \"forms/form.html\"\n\n% load exfiltry\n% load exsyntax\n\n\n%% all\n    %with table_type='datatable' table_subtype='table_with_details' table_details_height=\"40vh\" show_title_bar=1 title=_(\"Books catalog\")\n        {{ block.super }}\n\n\n%% list_content_actions\n    % new_row _(\"Add new book\")\n\n%% list_row_header\n    th...Inv. No.\n    th...Title\n    th...Author\n    th...ISBN\n    th...Category\n    th...Status\n    th...Acquired\n\n\n%% list_row\n    td...{{object.inventory_number}}\n    td...{{object.title}}\n    td...{{object.author}}\n    td...{{object.isbn}}\n    td...{{object.category}}\n    td\n        % if object.status == 'available':\n            span class=badge bg-success...{{object.get_status_display}}\n        % else:\n            % if object.status == 'borrowed':\n                span class=badge bg-warning...{{object.get_status_display}}\n            % else:\n                span class=badge bg-secondary...{{object.get_status_display}}\n    td...{{object.acquisition_date|isoformat}}\n\n%% list_row_actions\n    % if object.status == 'available':\n        % row_actions:\n            .borrow_book,Borrow book,[fa fa-sign-out]\n    % else:\n        % if object.status == 'borrowed':\n            % row_actions:\n        % else:\n            % row_actions:\n    % row_actions:\n        .edit\n        % if object.status != 'borrowed':\n            .withdraw_book,Withdraw,[fa fa-trash]\n        % if object.status != 'borrowed':\n            .delete\n\n%% list_page_footer\n    % row_details:\n        *Borrow history:schbook/table/Borrow//book__[[table_row_pk]]/form/schbook/sublist/\n\n\n%% row_edit\n    % form:\n        .inventory_number,title,author,isbn,publisher,publication_year,category,status,acquisition_date\n\n",
                        "tags_mount": null,
                        "asynchronous": false
                    }
                },
                {
                    "model": "SChTemplate",
                    "attributes": {
                        "name": "Borrow",
                        "direct_to_template": null,
                        "url": null,
                        "url_parm": null,
                        "template_code": "{# -*- coding: utf-8 -*- #}\n% extends \"forms/form.html\"\n\n% load exfiltry\n% load exsyntax\n\n\n%% all\n    %with table_type='datatable' show_title_bar=1 title=_(\"Borrow register\")\n        {{ block.super }}\n\n\n%% list_content_actions\n    % new_row _(\"New borrow entry\")\n\n%% list_row_header\n    th...Book\n    th...Reader\n    th...Email\n    th...Borrow date\n    th...Planned return\n    th...Return date\n\n\n%% list_row\n    td...{{object.book}}\n    td...{{object.reader_name}}\n    td...{{object.reader_email}}\n    td...{{object.borrow_date|isoformat}}\n    td...{{object.planned_return_date|isoformat}}\n    td\n        % if object.return_date:\n            {{object.return_date|isoformat}}\n        % else:\n            span class=badge bg-warning...Not returned\n\n%% list_row_actions\n    % if not object.return_date:\n        % row_actions:\n            .return_book,Return book,[fa fa-sign-in]\n    % row_actions:\n        .edit\n        .delete\n\n\n%% row_edit\n    % form:\n        .book,reader_name,reader_email,reader_phone,borrow_date,planned_return_date,return_date,notes\n\n",
                        "tags_mount": null,
                        "asynchronous": false
                    }
                },
                {
