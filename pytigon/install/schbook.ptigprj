                        "metaclass_code": null,
                        "table_code": "def save(self, *args, **kwargs):\n    from .models import Book\n    if self.return_date and not self._state.adding:\n        old = Borrow.objects.filter(pk=self.pk).first()\n        if old and not old.return_date:\n            try:\n                book = Book.objects.get(pk=self.book_id)\n                book.status = 'available'\n                book.save()\n            except Book.DoesNotExist:\n                pass\n    super().save(*args, **kwargs)\n",
