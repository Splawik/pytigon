                    "model": "SChTable",
                    "attributes": {
                        "base_table": "schelements.Element",
                        "name": "Book",
                        "verbose_name": "Book",
                        "verbose_name_plural": "Books",
                        "metaclass_code": null,
                        "table_code": "def init_new(self, request, view, param=None):\n    super().init_new(request, view, param)\n    self.type = 'E-BOOK'\n    self.name = 'new'\n    self.status = 'available'\n    self.acquisition_date = timezone.now().date()\n\ndef save(self, *args, **kwargs):\n    if not self.id and not self.inventory_number:\n        from .models import Book\n        last = Book.objects.order_by('-id').first()\n        if last and last.inventory_number:\n            try:\n                num = int(last.inventory_number) + 1\n                self.inventory_number = str(num).zfill(6)\n            except ValueError:\n                self.inventory_number = None\n    if not self.name or self.name == 'new':\n        self.name = self.title[:30] if self.title else 'untitled'\n    super().save(*args, **kwargs)\n",
                        "ordering": "['id']",
