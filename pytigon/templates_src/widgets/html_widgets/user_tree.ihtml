% extends "widgets/html_widgets/treeview.html"

% load exfiltry
% load exsyntax

%% widget_content
    <div class='tree user-tree'{% if not standard_web_browser %} width='300' height='120'{% endif %}>
        ul class=root
            li class=show_node user-tree-show-node
                span class=root user-tree-root-icon
                    {% icon "fa-plus fa-lg" %}
                    {{title}}

                ul class=children
                    {{data}}
    </div>